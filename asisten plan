```python
# app/core/query_classifier.py

class QueryClassifier:
    """
    Classify query TANPA panggil LLM (rule-based + small model)
    → Zero extra token cost!
    """

    # Keywords untuk fast classification
    SIMPLE_PATTERNS = [
        r"^(hi|hello|halo|hey|thanks|ok|oke|terima kasih)",
        r"^(apa itu|what is|siapa|who is) \w{1,20}$",
        r"^(ya|tidak|yes|no|iya|bukan)$",
    ]

    COMPLEX_PATTERNS = [
        r"(buatkan|buat|create|build|develop|implement)",
        r"(analisis|analyze|compare|bandingkan|evaluasi)",
        r"(jelaskan secara detail|explain in detail|step by step)",
        r"(debug|fix|refactor|optimize)",
        r"(essay|artikel|paper|laporan|report)",
    ]

    CODING_PATTERNS = [
        r"(code|kode|function|fungsi|class|api|database|sql|python|javascript)",
        r"(bug|error|exception|traceback)",
    ]

    async def classify(self, message: str) -> ProcessedQuery:
        message_lower = message.lower().strip()
        word_count = len(message.split())

        # Rule-based classification (instant, no API call)
        complexity = self._detect_complexity(message_lower, word_count)
        category = self._detect_category(message_lower)
        needs_memory = self._needs_memory(message_lower)

        return ProcessedQuery(
            original=message,
            complexity=complexity,
            category=category,
            needs_memory=needs_memory,
            needs_tools="search" in message_lower or "cari" in message_lower,
            estimated_tokens=word_count * 1.5,
        )

    def _detect_complexity(self, msg: str, word_count: int) -> str:
        if word_count < 10 and any(
            re.match(p, msg) for p in self.SIMPLE_PATTERNS
        ):
            return "simple"

        if any(re.search(p, msg) for p in self.COMPLEX_PATTERNS):
            return "complex"

        if word_count > 50:
            return "complex"

        return "moderate"

    def _needs_memory(self, msg: str) -> bool:
        """Apakah query ini butuh long-term memory?"""
        memory_triggers = [
            "kemarin", "sebelumnya", "yang tadi", "ingat",
            "remember", "previously", "last time", "you said",
            "seperti yang", "sudah pernah", "yang lalu",
        ]
        return any(trigger in msg for trigger in memory_triggers)


# app/core/model_router.py

class ModelRouter:
    """
    Route ke model yang paling cost-effective
    berdasarkan complexity query.
    """

    MODEL_TIERS = {
        "simple": {
            "primary": "gpt-3.5-turbo",      # $0.0005/1K tokens
            "fallback": "claude-3-haiku",
        },
        "moderate": {
            "primary": "gpt-4o-mini",         # $0.00015/1K tokens
            "fallback": "claude-3-haiku",
        },
        "complex": {
            "primary": "claude-3.5-sonnet",   # Best quality/price
            "fallback": "gpt-4o",
        },
        "creative": {
            "primary": "claude-3.5-sonnet",
            "fallback": "gpt-4o",
        },
    }

    def select_model(
        self, complexity: str, category: str, token_budget: int
    ) -> str:
        # Jika user hampir kehabisan budget → paksa model murah
        if token_budget < 1000:
            return "gpt-3.5-turbo"

        tier = self.MODEL_TIERS.get(complexity, self.MODEL_TIERS["moderate"])
        return tier["primary"]
