### 5.2 Brain Orchestrator (Inti Logic)

```python
# app/core/orchestrator.py
import asyncio
from dataclasses import dataclass
from typing import AsyncGenerator, Optional

@dataclass
class ProcessedQuery:
    original: str
    complexity: str          # "simple" | "moderate" | "complex"
    category: str            # "coding" | "writing" | "research" | "casual"
    needs_memory: bool       # Apakah perlu retrieve memory?
    needs_tools: bool        # Apakah perlu external tools?
    estimated_tokens: int

class BrainOrchestrator:
    """
    Otak utama aplikasi. Mengorkestrasi semua komponen
    untuk menghasilkan response yang optimal.
    """

    def __init__(
        self,
        memory_manager,
        query_classifier,
        prompt_compiler,
        model_router,
        llm_gateway,
        cache_store,
    ):
        self.memory = memory_manager
        self.classifier = query_classifier
        self.prompt_compiler = prompt_compiler
        self.router = model_router
        self.llm = llm_gateway
        self.cache = cache_store

    async def process_message(
        self,
        user_id: str,
        conversation_id: str,
        message: str,
    ) -> AsyncGenerator[str, None]:
        """
        Main pipeline: Message masuk → Response keluar (streaming)
        """

        # ━━━ STEP 1: Classify Query ━━━
        query = await self.classifier.classify(message)
        # Output: ProcessedQuery(complexity="moderate", category="coding", ...)

        # ━━━ STEP 2: Check Cache ━━━
        cached = await self.cache.get_response(message, user_id)
        if cached:
            yield cached
            return

        # ━━━ STEP 3: Retrieve Relevant Memory (PARALLEL) ━━━
        working_mem, relevant_mem, user_profile = await asyncio.gather(
            # Always: get recent messages (last 3-5)
            self.memory.get_working_memory(user_id, conversation_id),
            # Conditional: semantic search hanya jika perlu
            self.memory.retrieve_relevant(user_id, message, top_k=3)
                if query.needs_memory else asyncio.coroutine(lambda: [])(),
            # Always: get user profile (cached in Redis)
            self.memory.get_user_profile(user_id),
        )

        # ━━━ STEP 4: Compile Optimized Prompt ━━━
        compiled_prompt = self.prompt_compiler.compile(
            system_context=self._get_system_prompt(query.category),
            user_profile=user_profile,
            relevant_memories=relevant_mem,     # Only top-K relevant
            recent_messages=working_mem,         # Only last 3-5
            current_message=message,
            max_context_tokens=self._get_max_context(query.complexity),
        )

        # ━━━ STEP 5: Route to Best Model ━━━
        model = self.router.select_model(
            complexity=query.complexity,
            category=query.category,
            token_budget=self._get_token_budget(user_id),
        )
        # simple → "gpt-3.5-turbo" (fast & cheap)
        # moderate → "claude-3-haiku"
        # complex → "gpt-4o" / "claude-3.5-sonnet"

        # ━━━ STEP 6: Stream Response ━━━
        full_response = ""
        async for chunk in self.llm.stream(
            model=model,
            messages=compiled_prompt,
            max_tokens=self._get_max_output(query.complexity),
        ):
            full_response += chunk
            yield chunk

        # ━━━ STEP 7: Post-Processing (ASYNC, non-blocking) ━━━
        asyncio.create_task(
            self._post_process(
                user_id, conversation_id,
                message, full_response, query
            )
        )

    async def _post_process(
        self, user_id, conversation_id,
        user_msg, ai_response, query
    ):
        """Background tasks setelah response dikirim (tidak blocking user)"""

        # Save messages ke DB
        await self.memory.save_messages(
            conversation_id, user_msg, ai_response
        )

        # Update working memory di Redis
        await self.memory.update_working_memory(
            user_id, conversation_id, user_msg, ai_response
        )

        # Extract & store facts (async, pakai model kecil/murah)
        await self.memory.extract_and_store_facts(
            user_id, conversation_id, user_msg, ai_response
        )

        # Compress jika working memory terlalu panjang
        await self.memory.compress_if_needed(
            user_id, conversation_id
        )

        # Cache response
        await self.cache.store_response(user_msg, user_id, ai_response)

    def _get_max_context(self, complexity: str) -> int:
        """Token budget untuk context berdasarkan complexity"""
        return {
            "simple": 500,       # Hemat banget
            "moderate": 2000,
            "complex": 4000,
        }.get(complexity, 2000)

    def _get_max_output(self, complexity: str) -> int:
        return {
            "simple": 300,
            "moderate": 1000,
            "complex": 4000,
        }.get(complexity, 1000)
```

### 5.3 Memory Manager

```python
# app/memory/memory_manager.py
from datetime import datetime, timedelta
import numpy as np

class MemoryManager:
    """
    Manages 3-tier memory system:
    Tier 1 (Working) → Redis
    Tier 2 (Short-term) → PostgreSQL
    Tier 3 (Long-term) → Vector DB
    """

    def __init__(self, redis, postgres, vector_store, embedder, compressor):
        self.redis = redis
        self.db = postgres
        self.vectors = vector_store
        self.embedder = embedder
        self.compressor = compressor

    # ═══════════════════════════════════════════
    # TIER 1: WORKING MEMORY (Redis)
    # ═══════════════════════════════════════════

    async def get_working_memory(
        self, user_id: str, conv_id: str, limit: int = 5
    ) -> list[dict]:
        """Get last N messages dari Redis (ultra-fast)"""
        key = f"session:{user_id}:{conv_id}:messages"
        messages = await self.redis.lrange(key, -limit, -1)
        return [json.loads(m) for m in messages]

    async def update_working_memory(
        self, user_id, conv_id, user_msg, ai_response
    ):
        key = f"session:{user_id}:{conv_id}:messages"

        # Push new messages
        await self.redis.rpush(key, json.dumps({
            "role": "user", "content": user_msg,
            "timestamp": datetime.now().isoformat()
        }))
        await self.redis.rpush(key, json.dumps({
            "role": "assistant", "content": ai_response,
            "timestamp": datetime.now().isoformat()
        }))

        # Keep only last 10 messages (5 pairs)
        await self.redis.ltrim(key, -10, -1)

        # Set TTL 30 minutes
        await self.redis.expire(key, 1800)

    # ═══════════════════════════════════════════
    # TIER 2: SHORT-TERM MEMORY (PostgreSQL)
    # ═══════════════════════════════════════════

    async def compress_if_needed(self, user_id: str, conv_id: str):
        """
        Jika conversation sudah > 20 messages,
        compress older messages menjadi summary
        """
        msg_count = await self.db.get_message_count(conv_id)

        if msg_count > 20:
            # Ambil messages lama (bukan 5 terakhir)
            old_messages = await self.db.get_messages(
                conv_id, offset=0, limit=msg_count - 5
            )

            # Compress pakai model kecil & murah
            summary = await self.compressor.summarize(
                old_messages,
                max_tokens=200,  # Compress jadi max 200 token
                model="gpt-3.5-turbo"  # Model murah untuk kompresi
            )

            # Save summary, mark old messages as compressed
            await self.db.save_session_summary(
                user_id, conv_id, summary,
                original_tokens=count_tokens(old_messages),
                compressed_tokens=count_tokens(summary),
            )

            # Mark old messages (bisa di-delete atau flag)
            await self.db.mark_compressed(conv_id, msg_count - 5)

    # ═══════════════════════════════════════════
    # TIER 3: LONG-TERM MEMORY (Vector DB)
    # ═══════════════════════════════════════════

    async def retrieve_relevant(
        self, user_id: str, query: str, top_k: int = 3
    ) -> list[dict]:
        """
        Semantic search: cari memory yang RELEVAN dengan query saat ini.
        Hanya return top-K → hemat token!
        """
        # Generate embedding dari query user
        query_embedding = await self.embedder.embed(query)

        # Search di Vector DB dengan filter user_id
        results = await self.vectors.search(
            collection="user_memories",
            vector=query_embedding,
            filter={"user_id": user_id, "decay_score": {"$gt": 0.3}},
            top_k=top_k,
        )

        # Update access count & decay score
        for r in results:
            await self._boost_memory(r["id"])

        return [
            {"content": r["content"], "relevance": r["score"]}
            for r in results
            if r["score"] > 0.7  # Threshold relevansi
        ]

    async def extract_and_store_facts(
        self, user_id, conv_id, user_msg, ai_response
    ):
        """
        Extract factual information dari percakapan
        dan simpan ke long-term memory.

        Contoh:
        User: "Saya kerja sebagai data scientist di Tokopedia"
        → Extract: {type: "personal", key: "job", value: "Data Scientist"}
        → Extract: {type: "personal", key: "company", value: "Tokopedia"}
        """
        # Pakai model kecil untuk extract facts
        extraction_prompt = f"""
        Extract factual information from this conversation.
        Return JSON array of facts. Only extract CLEAR facts.

        User: {user_msg}
        Assistant: {ai_response}

        Format: [{{"type": "personal|preference|knowledge",
                   "key": "...", "value": "..."}}]
        """

        facts = await self.llm.complete(
            model="gpt-3.5-turbo",  # Model murah
            prompt=extraction_prompt,
            max_tokens=200,
        )

        for fact in parse_facts(facts):
            # Check if fact already exists (avoid duplicates)
            existing = await self.db.find_fact(
                user_id, fact["type"], fact["key"]
            )

            if existing:
                # Update existing fact
                await self.db.update_fact(existing["id"], fact["value"])
            else:
                # Store new fact + embedding
                embedding = await self.embedder.embed(
                    f"{fact['key']}: {fact['value']}"
                )

                await self.vectors.upsert(
                    collection="user_memories",
                    id=str(uuid4()),
                    vector=embedding,
                    payload={
                        "user_id": user_id,
                        "fact_type": fact["type"],
                        "content": f"{fact['key']}: {fact['value']}",
                        "source_conversation_id": conv_id,
                        "created_at": datetime.now().isoformat(),
                        "decay_score": 1.0,
                        "access_count": 0,
                    }
                )

                # Also store in PostgreSQL for fast lookup
                await self.db.insert_fact(user_id, conv_id, fact)

    # ═══════════════════════════════════════════
    # MEMORY DECAY (Cleanup)
    # ═══════════════════════════════════════════

    async def run_decay_cycle(self):
        """
        Jalankan periodic (cron job) untuk decay memory
        yang jarang diakses. Hemat storage!
        """
        all_facts = await self.db.get_all_facts_for_decay()

        for fact in all_facts:
            days_since_access = (
                datetime.now() - fact["last_accessed"]
            ).days

            # Decay formula: score *= 0.95^days_since_last_access
            new_decay = fact["decay_score"] * (0.95 ** days_since_access)

            if new_decay < 0.1:
                # Memory terlalu lama tidak diakses → archive/delete
                await self.db.archive_fact(fact["id"])
                await self.vectors.delete(fact["id"])
            else:
                await self.db.update_decay_score(fact["id"], new_decay)
