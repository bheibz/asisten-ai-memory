## 📊 3. DATABASE SCHEMA

### 3.1 PostgreSQL — Relational Data

```sql
-- ============================================
-- USERS TABLE
-- ============================================
CREATE TABLE users (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    username        VARCHAR(100) UNIQUE NOT NULL,
    email           VARCHAR(255) UNIQUE,
    settings        JSONB DEFAULT '{}',
    -- Auto-built profile dari percakapan
    ai_profile      JSONB DEFAULT '{
        "name": null,
        "language_pref": "id",
        "expertise_level": "general",
        "interests": [],
        "communication_style": "casual",
        "known_facts": {}
    }',
    total_tokens_used   BIGINT DEFAULT 0,
    created_at      TIMESTAMP DEFAULT NOW(),
    updated_at      TIMESTAMP DEFAULT NOW()
);

-- ============================================
-- CONVERSATIONS TABLE
-- ============================================
CREATE TABLE conversations (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id         UUID REFERENCES users(id) ON DELETE CASCADE,
    title           VARCHAR(500),
    category        VARCHAR(50), -- 'coding', 'writing', 'research', 'casual', etc.
    summary         TEXT, -- Compressed summary of entire conversation
    message_count   INT DEFAULT 0,
    total_tokens    INT DEFAULT 0,
    model_used      VARCHAR(50),
    is_archived     BOOLEAN DEFAULT FALSE,
    created_at      TIMESTAMP DEFAULT NOW(),
    updated_at      TIMESTAMP DEFAULT NOW()
);

-- ============================================
-- MESSAGES TABLE
-- ============================================
CREATE TABLE messages (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    conversation_id UUID REFERENCES conversations(id) ON DELETE CASCADE,
    role            VARCHAR(20) NOT NULL, -- 'user', 'assistant', 'system'
    content         TEXT NOT NULL,
    -- Token tracking per message
    tokens_input    INT DEFAULT 0,
    tokens_output   INT DEFAULT 0,
    -- Metadata
    model_used      VARCHAR(50),
    response_time_ms INT,
    compressed      BOOLEAN DEFAULT FALSE, -- sudah di-compress?
    metadata        JSONB DEFAULT '{}',
    created_at      TIMESTAMP DEFAULT NOW()
);

-- Index untuk fast retrieval
CREATE INDEX idx_messages_conversation ON messages(conversation_id, created_at DESC);
CREATE INDEX idx_conversations_user ON conversations(user_id, updated_at DESC);

-- ============================================
-- MEMORY FACTS TABLE (Extracted Knowledge)
-- ============================================
CREATE TABLE memory_facts (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id         UUID REFERENCES users(id) ON DELETE CASCADE,
    fact_type       VARCHAR(50) NOT NULL,
    -- Types: 'personal', 'preference', 'knowledge', 'instruction', 'context'
    fact_key        VARCHAR(200),  -- e.g., "programming_language", "name", "job"
    fact_value      TEXT NOT NULL,  -- e.g., "Python", "Budi", "Data Scientist"
    source_conversation UUID REFERENCES conversations(id),
    confidence      FLOAT DEFAULT 1.0,   -- 0.0 - 1.0
    access_count    INT DEFAULT 0,       -- berapa kali di-retrieve
    decay_score     FLOAT DEFAULT 1.0,   -- makin jarang dipakai, makin turun
    last_accessed   TIMESTAMP DEFAULT NOW(),
    created_at      TIMESTAMP DEFAULT NOW(),
    updated_at      TIMESTAMP DEFAULT NOW()
);

CREATE INDEX idx_facts_user ON memory_facts(user_id, fact_type);
CREATE INDEX idx_facts_decay ON memory_facts(decay_score DESC);

-- ============================================
-- SESSION SUMMARIES (Compressed Memory)
-- ============================================
CREATE TABLE session_summaries (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id         UUID REFERENCES users(id),
    conversation_id UUID REFERENCES conversations(id),
    summary         TEXT NOT NULL,        -- Compressed summary
    key_topics      TEXT[] DEFAULT '{}',  -- Array of topics discussed
    token_count     INT,                  -- Token dari summary ini
    original_tokens INT,                  -- Token asli sebelum compress
    compression_ratio FLOAT,             -- Rasio kompresi
    created_at      TIMESTAMP DEFAULT NOW()
);
```

