# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/aichat
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=sk-or-v1-...

# LLM API Keys (fallback)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# App
APP_NAME=AI Chat with Memory
AI_NAME=Clara
DEBUG=true
LOG_LEVEL=INFO
MAX_WORKING_MEMORY_MESSAGES=10
WORKING_MEMORY_TTL=1800
DEFAULT_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
EMBEDDING_MODEL=text-embedding-ada-002

# Cerebras (ultra-fast inference)
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
